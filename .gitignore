# 白名单
/*
/*/
# !*/

# 密钥文件
api.key

# Go modules - 必须版本控制
!go.mod
!go.sum

# 核心文件夹
!plan
!example
!internal
!pkg
!cmd

# 注意：根目录的 config/ 是运行时 -init 生成的，不应提交
# cmd/config/ 是嵌入的默认配置，已包含在白名单内
!/cmd/config/api.key

# 工具
!.agents
!agent-refer
!build.sh

# Python 脚本
!scripts/

# 基本文件/夹
!*code-workspace
!.gitignore
!LICENSE
!README.md
!AGENTS.md
!CLAUDE.md
!PLAN.md
!RULE.md